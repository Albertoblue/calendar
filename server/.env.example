# Copia este archivo a `.env` y completa tus valores reales.

# Puerto del servidor
PORT=4000

# Cadena de conexion de MongoDB Atlas.
# Sacala de: Atlas -> Cluster -> Connect -> Drivers -> Node.js
# Recuerda reemplazar <user>, <password> y el nombre del cluster.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nuestro-calendario?retryWrites=true&w=majority

# Secreto para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Origen permitido para CORS (el frontend en desarrollo)
CLIENT_ORIGIN=http://localhost:5173

# --- APIs externas para el apartado Ideas (opcionales) ---
# Si las dejas vacias, Ideas funciona en modo manual (anadir a mano).

# TMDB (peliculas/series): https://www.themoviedb.org/settings/api -> API Key (v3 auth)
TMDB_API_KEY=

# Google Places API New (lugares): Google Cloud Console -> APIs -> Places API (New) -> Credenciales
GOOGLE_PLACES_KEY=

# Anthropic / Claude (sugeridor de planes con IA): https://console.anthropic.com -> API Keys
# Si la dejas vacia, el sugeridor con IA queda desactivado (el resto de la app funciona igual).
ANTHROPIC_API_KEY=
